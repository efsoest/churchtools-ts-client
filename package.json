{
  "name": "churchtools-ts-client",
  "version": "0.1.0",
  "description": "Type-safe ChurchTools API client",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generated": {
      "types": "./src/generated/openapi/index.ts",
      "import": "./dist/generated/index.js",
      "require": "./dist/generated/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "generated": [
        "src/generated/openapi/index.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src/generated/openapi"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "typecheck:generated": "tsc --project tsconfig.generated.json --noEmit",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun test --watch",
    "smoke:e2e": "bun run scripts/smoke-e2e.ts",
    "generate": "bun run scripts/generate-api.ts",
    "postprocess:generated": "bun run scripts/postprocess-generated.ts",
    "generate:all": "bun run generate && bun run postprocess:generated && bun run typecheck:generated",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.28.3",
    "@types/bun": "^1.3.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
